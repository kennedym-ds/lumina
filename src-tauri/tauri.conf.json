{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumina",
  "version": "2.1.0",
  "identifier": "com.lumina.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lumina",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https://tauri.localhost; connect-src 'self' http://127.0.0.1:* tauri: https://tauri.localhost; img-src 'self' data: blob: tauri: https://tauri.localhost; script-src 'self' 'unsafe-eval' tauri: https://tauri.localhost; style-src 'self' 'unsafe-inline' tauri: https://tauri.localhost; font-src 'self' data: tauri: https://tauri.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "lumina"
        ],
        "mimeType": "application/x-lumina-project",
        "description": "Lumina Project File"
      }
    ],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "lumina-backend",
          "cmd": "binaries/lumina-backend",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}