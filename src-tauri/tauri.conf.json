{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/packages/api/info/schema.json",
  "productName": "Lumina",
  "version": "1.0.0",
  "identifier": "com.lumina.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "title": "Lumina",
    "windows": [
      {
        "title": "Lumina",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "binaries/lumina-backend-x86_64-pc-windows-msvc/**"
    ],
    "fileAssociations": [
      {
        "ext": [
          "lumina"
        ],
        "mimeType": "application/x-lumina-project",
        "description": "Lumina Project File"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "lumina-backend",
          "cmd": "binaries/lumina-backend",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}